{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "8voice",
  "version": "0.2.41",
  "identifier": "com.8voice.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "8voice",
        "label": "main",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "center": true,
        "visible": false
      },
      {
        "title": "8voice",
        "label": "widget",
        "url": "widget.html",
        "width": 90,
        "height": 40,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE0M0ZBMDY0QjA2QTBDODMKUldTRERHcXdaS0EvRkRnK0ZkRUFxWmU3dVY0QUVPemN2WENRVm0rN2s3TUdwVW1hSHdrcEFUa3cK",
      "endpoints": [
        "https://github.com/alparlsan88/8voice/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
